---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{title}</title>
	<meta name="description" content="Paul Vié — Engineering student at Télécom Paris, cryptography research" />
	<!-- Add a favicon here: <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
	<nav>
		<div class="nav-inner">
			<a href="/" class="nav-name">Paul Vié</a>
			<div class="nav-links">
				<a href="#about">About</a>
				<a href="#publications">Publications</a>
				<a href="#talks">Talks</a>
				<a href="#projects">Projects</a>
				<a href="#education">Education</a>
				<a href="/cv.pdf">CV</a>
			</div>
		</div>
	</nav>
	<main>
		<slot />
	</main>
	<footer>
		<p>Paul Vié — paul.vie@telecom-paris.fr</p>
	</footer>
</body>
</html>

<style is:global>
	* { margin: 0; padding: 0; box-sizing: border-box; }

	body {
		font-family: 'Inter', system-ui, sans-serif;
		color: #1a1a1a;
		background: #fff;
		line-height: 1.6;
	}

	nav {
		position: sticky;
		top: 0;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid #e5e7eb;
		z-index: 100;
	}

	.nav-inner {
		max-width: 800px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.nav-name {
		font-family: 'Source Serif 4', Georgia, serif;
		font-weight: 600;
		font-size: 1.1rem;
		color: #1a1a1a;
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.nav-links a {
		color: #555;
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.15s;
	}

	.nav-links a:hover {
		color: #1a1a1a;
	}

	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	section {
		padding: 2.5rem 0;
		border-bottom: 1px solid #f0f0f0;
	}

	section:last-child {
		border-bottom: none;
	}

	h2 {
		font-family: 'Source Serif 4', Georgia, serif;
		font-size: 1.35rem;
		font-weight: 600;
		margin-bottom: 1.25rem;
		color: #1a1a1a;
	}

	h3 {
		font-size: 0.95rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	a {
		color: #2563eb;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	p {
		margin-bottom: 0.75rem;
	}

	footer {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		text-align: center;
		color: #999;
		font-size: 0.85rem;
	}

	/* Hero / header section */
	.hero {
		display: flex;
		gap: 2rem;
		align-items: center;
		padding: 3rem 0 2rem;
	}

	.hero img {
		width: 150px;
		height: 150px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}

	.hero-text h1 {
		font-family: 'Source Serif 4', Georgia, serif;
		font-size: 1.75rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	.hero-text .subtitle {
		color: #555;
		font-size: 1rem;
		margin-bottom: 0.75rem;
	}

	.hero-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.hero-links a {
		color: #555;
		font-size: 0.9rem;
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.hero-links a:hover {
		color: #1a1a1a;
	}

	/* Publication list */
	.pub {
		margin-bottom: 1.25rem;
	}

	.pub .authors {
		font-size: 0.9rem;
		color: #444;
	}

	.pub .title {
		font-weight: 500;
	}

	.pub .venue {
		font-size: 0.85rem;
		color: #777;
	}

	.pub .links {
		font-size: 0.85rem;
		margin-top: 0.2rem;
	}

	.pub .links a {
		margin-right: 0.75rem;
	}

	/* Talk list */
	.talk {
		margin-bottom: 1rem;
		display: flex;
		gap: 1rem;
	}

	.talk .date {
		color: #999;
		font-size: 0.85rem;
		min-width: 100px;
		flex-shrink: 0;
	}

	/* Education timeline */
	.edu-item {
		margin-bottom: 1.25rem;
	}

	.edu-item .period {
		color: #999;
		font-size: 0.85rem;
	}

	.edu-item p {
		font-size: 0.9rem;
		color: #555;
		margin-bottom: 0;
	}

	/* Project card */
	.project {
		margin-bottom: 1.25rem;
	}

	.project p {
		font-size: 0.9rem;
		color: #555;
	}

	.project .links {
		font-size: 0.85rem;
		margin-top: 0.2rem;
	}

	.project .links a {
		margin-right: 0.75rem;
	}

	/* Teaching */
	.teaching-item {
		margin-bottom: 0.75rem;
		display: flex;
		gap: 1rem;
	}

	.teaching-item .period {
		color: #999;
		font-size: 0.85rem;
		min-width: 100px;
		flex-shrink: 0;
	}

	/* Responsive */
	@media (max-width: 600px) {
		.hero {
			flex-direction: column;
			text-align: center;
		}
		.hero-links {
			justify-content: center;
		}
		.talk, .teaching-item {
			flex-direction: column;
			gap: 0.15rem;
		}
		.talk .date, .teaching-item .period {
			min-width: auto;
		}
	}
</style>
